# 备件管理系统 - 环境变量示例
# 复制此文件为 .env 并按环境修改；勿将 .env 提交到版本库

# ========== 项目与运行 ==========
# DEBUG=False  # 生产必须关闭
# SECRET_KEY=请使用强随机字符串，如: openssl rand -hex 32
# CORS_ORIGINS=https://your-frontend-domain.com   # 生产前端地址，逗号分隔多个

# ========== 数据库 ==========
# DATABASE_URL=mysql+pymysql://用户:密码@主机:3306/数据库名

# ========== MinIO（图片存储）==========
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET_NAME=spareparts
# MINIO_SECURE=false

# ========== 前端与回调 ==========
# FRONTEND_URL=https://your-frontend-domain.com   # 企业微信回调等重定向目标
# 工厂新媒体代理部署时设为 /zs2sbgl/，白码同域为 /spare/，留空则按根路径
# VITE_BASE_PATH=/zs2sbgl/

# ========== SSO 单点登录（工厂新媒体代理必配）==========
# SSO_ENABLED=true
# SSO_CLIENT_ID=zs2sbgl
# SSO_CLIENT_SECRET=由信息科提供
# SSO_BASE_URL=https://yxcf-yzyy.ynzy-tobacco.com/
# SSO_REALM=yxcf
# 授权回调必须与单点登录侧登记一致，且为代理后的外网地址（urlencode 后登记）
# SSO_REDIRECT_URI=https://yxcf-yzyy.ynzy-tobacco.com/zs2sbgl/sso/callback

# ========== 企业微信（可选，不配置则无扫码登录入口）==========
# WECHAT_CORP_ID=
# WECHAT_CORP_SECRET=
# WECHAT_AGENT_ID=
# WECHAT_REDIRECT_URI=https://your-api-domain.com/api/v1/wechat/callback

# ========== 其他 ==========
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REDIS_URL=redis://redis:6379/0
